{
    "name": "@chili3d/mcp",
    "version": "0.7.0-beta",
    "description": "Headless MCP server for Chili3D — AI-driven, editable parametric CAD generation over a shared OCCT geometry core",
    "type": "module",
    "main": "src/index.ts",
    "bin": {
        "chili3d-mcp": "dist/server.mjs"
    },
    "scripts": {
        "build": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --external:@modelcontextprotocol/* --external:zod --external:ws",
        "start": "node dist/server.mjs",
        "bridge": "tsx scripts/bridge.ts",
        "demo": "esbuild scripts/demo-loop.ts --bundle --platform=node --format=esm --outfile=dist/demo.mjs --external:@modelcontextprotocol/* --external:zod && node dist/demo.mjs"
    },
    "devDependencies": {
        "@chili3d/app": "*",
        "@chili3d/core": "*",
        "@chili3d/wasm": "*",
        "@types/ws": "^8.18.1",
        "esbuild": "^0.28.0",
        "tsx": "^4.22.3"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    }
}
